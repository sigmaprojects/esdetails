# Environment variable overrides — copy to .env and edit as needed

# Ollama or open-webui base URL visible from within the Docker container.
# If Ollama runs on the same Docker host, use host.docker.internal:
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default model for vision tasks (must support image input, e.g. llava, llava-llama3)
OLLAMA_MODEL=llava

# Web server port (also change the ports mapping in docker-compose.yml if you modify this)
PORT=3000
